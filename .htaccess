# ============================================================
# Ntabou Aka Wé — Configuration Apache (.htaccess)
# Compatible : cPanel, OVH, Infomaniak, LWS, PlanetHoster…
# ============================================================

Options -Indexes
DirectoryIndex index.html

# ---- Encodage UTF-8 ----
AddDefaultCharset UTF-8
AddCharset UTF-8 .html .js .css

# ---- Compression GZIP (chargement plus rapide) ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# ---- Cache navigateur ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
</IfModule>

# ---- Redirections URL propres (sans .html) ----
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Éviter les boucles sur les fichiers existants
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # URL propres → fichiers HTML
  RewriteRule ^admin$ /admin.html [L]
  RewriteRule ^profil$ /profil.html [L]
  RewriteRule ^connexion$ /connexion.html [L]
  RewriteRule ^inscription$ /inscription.html [L]
  RewriteRule ^histoire$ /histoire.html [L]
  RewriteRule ^soins-energetiques$ /services-energetiques.html [L]
  RewriteRule ^accompagnement$ /accompagnement.html [L]
  RewriteRule ^soins-direct$ /soins-direct.html [L]
  RewriteRule ^contact$ /contact.html [L]
  RewriteRule ^conditions$ /conditions.html [L]
  RewriteRule ^confidentialite$ /confidentialite.html [L]
</IfModule>

# ---- Page d'erreur 404 ----
ErrorDocument 404 /index.html

# ---- Sécurité : bloquer l'accès direct aux fichiers sensibles ----
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>
