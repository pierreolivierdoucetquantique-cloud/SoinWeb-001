# Copie ce fichier en ".env" pour le développement local (ne jamais commit le .env réel).
# Sur Render, configure ces mêmes variables dans Environment — pas de fichier .env là-bas.

# ---- Resend (courriels) ----
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Ntabou Aka Wé <notifications@tondomaine.com>

# ---- CORS ----
# Domaines autorisés à appeler cette API, séparés par des virgules, sans espace après la virgule si possible.
ALLOWED_ORIGINS=https://3pierre6olivier9.com,https://soinweb-sovara.onrender.com

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Optionnel ----
# Destinataire par défaut du bouton "Envoyer un email de test" si aucun n'est précisé
TEST_EMAIL_TO=admin@ntabou-aka-we.fr

# ---- Zoom (réunions automatiques à la confirmation d'un rendez-vous) ----
# Server-to-Server OAuth — https://marketplace.zoom.us/ → Develop → Build App
# Scopes requis : meeting:write:admin, meeting:update:admin, meeting:delete:admin
# (ou meeting:write / meeting:update / meeting:delete si compte non-admin)
ZOOM_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxx
ZOOM_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxx
ZOOM_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# ---- Google Calendar (événement automatique à la confirmation d'un rendez-vous) ----
# OAuth2 — https://console.cloud.google.com/ → activer "Google Calendar API"
#          puis APIs & Services → Identifiants → ID client OAuth (Application Web)
# GOOGLE_REDIRECT_URI doit être ajouté aux URI de redirection autorisés de l'app,
# et doit correspondre exactement à l'URL publique du serveur + /api/admin/google/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://ntabou-aka-we.onrender.com/api/admin/google/callback
# Après avoir configuré ces 3 variables : Admin → Paramètres → Intégrations →
# "Connecter Google Calendar" (autorisation unique, à refaire seulement si l'accès
# est révoqué manuellement depuis myaccount.google.com).
